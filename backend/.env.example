# Optional: override path for UI-saved LLM config (default: backend/data/llm_config.json)
# LLM_CONFIG_FILE=

# MiniMax OpenAI-compatible (recommended for M2.5 on api.minimaxi.com)
OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_API_KEY=your_api_key
MODEL_NAME=MiniMax-M2.5
MAX_TOKENS=4096

# If OPENAI_BASE_URL is unset, use API_BASE_URL + LLM_PROVIDER instead:
# LLM_PROVIDER=minimax | openrouter | anthropic
# MINIMAX_API_KEY= / API_BASE_URL=https://api.minimax.io / MODEL_NAME=M2-her
# OPENROUTER_API_KEY= / API_BASE_URL= / MODEL_NAME=
# ANTHROPIC_API_KEY= / API_BASE_URL=https://api.anthropic.com

HTTP_PROXY=
HTTPS_PROXY=

HOST=0.0.0.0
PORT=8000

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
